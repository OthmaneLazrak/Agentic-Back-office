{
  "realm": "awb-kyc",
  "enabled": true,
  "displayName": "AWB KYC",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 1800,
  "ssoSessionIdleTimeout": 3600,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "ADMIN",
        "description": "Administrateur — gestion des utilisateurs et configuration"
      },
      {
        "name": "FRONT_OFFICE",
        "description": "Agent Front Office — traite les dossiers KYC avec l'agent IA"
      },
      {
        "name": "BACK_OFFICE",
        "description": "Agent Back Office — traite manuellement les dossiers escaladés"
      }
    ]
  },
  "clients": [
    {
      "clientId": "kyc-frontend",
      "name": "AWB KYC Frontend (React)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:5174/*",
        "http://127.0.0.1:5173/*",
        "http://127.0.0.1:5174/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:5174",
        "http://127.0.0.1:5173",
        "http://127.0.0.1:5174",
        "+"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      },
      "fullScopeAllowed": true
    },
    {
      "clientId": "kyc-backend",
      "name": "AWB KYC Backend (Spring)",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "kyc-backend-secret-change-me",
      "attributes": {
        "use.refresh.tokens": "false"
      },
      "fullScopeAllowed": true
    }
  ],
  "users": [
    {
      "username": "service-account-kyc-backend",
      "enabled": true,
      "serviceAccountClientId": "kyc-backend",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users",
          "query-users",
          "manage-realm",
          "view-realm"
        ]
      }
    },
    {
      "username": "admin.kyc",
      "email": "admin@awb.local",
      "firstName": "Karim",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["ADMIN"]
    },
    {
      "username": "front.officer",
      "email": "front@awb.local",
      "firstName": "Othmane",
      "lastName": "Lazrek",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "front123",
          "temporary": false
        }
      ],
      "realmRoles": ["FRONT_OFFICE"]
    },
    {
      "username": "back.officer",
      "email": "back@awb.local",
      "firstName": "Imane",
      "lastName": "Bennani",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "back123",
          "temporary": false
        }
      ],
      "realmRoles": ["BACK_OFFICE"]
    }
  ]
}
